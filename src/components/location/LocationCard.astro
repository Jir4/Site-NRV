---
import type { Location } from "../../data/site";
import { getLocationOsmUrl } from "../../utils/maps";
import WeatherIcon from "../icons/WeatherIcon.astro";
import LocationActions from "./LocationActions.astro";

interface Props {
  location: Location;
  className?: string;
  relation?: "initiation" | "competition";
  routeTo?: boolean;
}

const { location, className = "", relation, routeTo = false } = Astro.props;
const osmUrl = getLocationOsmUrl(location);
---

<article
  class={`map-card ${className}`}
  data-route-to={routeTo ? true : undefined}
  data-relation={relation}
  data-location-id={location.id}
>
  <div class="map-content">
    <div class="location-heading">
      <div class="location-title">
        <h3>{location.name}</h3>
        <p>
          {location.type === "outdoor" ? "Outdoor" : "Indoor"} · {
            location.usage
          }
        </p>

        {
          location.conditions.length > 0 && (
            <div class="location-conditions" aria-label="Conditions météo">
              {location.conditions.map((condition) => (
                <span class={`weather-chip is-${condition.icon}`}>
                  <WeatherIcon icon={condition.icon} />
                  {condition.label}
                </span>
              ))}
            </div>
          )
        }
      </div>
    </div>

    <div class="location-place">
      <p class="location-label">Emplacement</p>
      <p class="location-address-text">{location.address}</p>
      <LocationActions location={location} />
    </div>
  </div>

  <figure class="map-frame">
    <a
      class="map-frame-link"
      href={osmUrl}
      target="_blank"
      rel="noreferrer"
      aria-label={`Ouvrir la carte de ${location.name} dans OpenStreetMap`}
    >
      <img
        src={`/generated/maps/${location.id}.webp`}
        alt={`Carte de ${location.name}`}
        loading="lazy"
        decoding="async"
      />
    </a>
    <figcaption>© OpenStreetMap contributors · © CARTO</figcaption>
  </figure>
</article>

<style>
  .map-card {
    position: relative;
    z-index: 4;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: white;
    box-shadow: 0 18px 50px rgba(16, 21, 16, 0.06);
    transition:
      transform 180ms ease,
      opacity 180ms ease,
      border-color 180ms ease,
      outline-color 180ms ease;
  }

  .map-card.is-bazin-location {
    z-index: 5;
    margin: 16px 0;
  }

  .map-card.is-schedule-target {
    transform: translateY(-3px);
    border-color: rgba(149, 194, 61, 0.9);
    outline: 4px solid rgba(149, 194, 61, 0.18);
  }

  .map-frame {
    position: relative;
    z-index: 0;
    height: 240px;
    margin: 0;
    overflow: hidden;
    background: rgba(149, 194, 61, 0.14);
    border-top: 1px solid var(--line);
  }

  .map-frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 180ms ease;
  }

  .map-frame-link {
    display: block;
    height: 100%;
    cursor: pointer;
  }

  .map-frame-link:hover img,
  .map-frame-link:focus-visible img {
    transform: scale(1.02);
  }

  .map-frame-link:focus-visible {
    outline: 3px solid rgba(149, 194, 61, 0.9);
    outline-offset: -3px;
  }

  .map-frame figcaption {
    position: absolute;
    right: 0;
    bottom: 0;
    padding: 2px 6px;
    background: rgba(255, 255, 255, 0.86);
    font-size: 0.66rem;
    color: rgba(16, 21, 16, 0.58);
  }

  .map-content {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 22px;
  }

  .location-heading {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
  }

  .location-title h3 {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.12;
  }

  .location-title p {
    margin: 5px 0 0;
    color: var(--club-text);
    font-family: var(--display);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .location-conditions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }

  .weather-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 7px;
    border-radius: 999px;
    background: rgba(149, 194, 61, 0.1);
    color: var(--ink);
    font-family: var(--display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .weather-chip :global(svg) {
    width: 14px;
    height: 14px;
    color: var(--club-text);
  }

  .location-place {
    margin: auto 0 16px;
    padding: 12px;
    border: 1px solid rgba(16, 21, 16, 0.08);
    border-radius: 16px;
    background: rgba(149, 194, 61, 0.08);
  }

  .location-label {
    margin: 0 0 6px;
    color: var(--club-text);
    font-family: var(--display);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .location-address-text {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }
</style>
