---
import heroPhoto from "../assets/club/photo0.webp";
import racePhoto from "../assets/club/photo1.webp";
import teamPhoto from "../assets/club/photo2.webp";
import competitionPhoto from "../assets/club/photo3.webp";
import trainingPhoto from "../assets/club/photo4.webp";
import PhotoStack from "./PhotoStack.astro";

interface Props {
  helloAssoUrl: string;
}

const { helloAssoUrl } = Astro.props;
const photos = [
  { src: heroPhoto, alt: "Entraînement du Nancy Roller Vitesse sur piste" },
  { src: racePhoto, alt: "Départ d'une course" },
  { src: teamPhoto, alt: "Les membres du club" },
  { src: competitionPhoto, alt: "Compétition de roller" },
  { src: trainingPhoto, alt: "Séance d'entraînement" },
];
---

<header class="hero" id="accueil">
  <div class="hero-inner">
    <div>
      <p class="eyebrow">Roller vitesse à Nancy</p>
      <h1>Le roller de vitesse commence ici, dès 5 ans.</h1>
      <p class="lead">
        À Nancy, enfants, ados et adultes trouvent un groupe adapté pour
        découvrir le roller, gagner en aisance, progresser techniquement et
        préparer les compétitions.
      </p>
      <div class="hero-actions">
        <a
          class="button"
          href={helloAssoUrl}
          target="_blank"
          rel="noreferrer"
          data-join-cta>S'inscrire</a
        >
        <a class="button secondary" href="#groupes"
          >Voir les groupes et horaires</a
        >
      </div>
    </div>
    <PhotoStack photos={photos} interval={3500} />
  </div>
</header>
