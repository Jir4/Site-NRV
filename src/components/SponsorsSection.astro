---
import { Image } from "astro:assets";
import grandNancyLogo from "../assets/partners/grand-nancy.png";
import villeNancyLogo from "../assets/partners/ville-nancy.png";

interface Props {
  sponsors: string[];
}
const { sponsors } = Astro.props;

const getSponsorLogo = (sponsor: string) => {
  if (sponsor === "Ville de Nancy") {
    return {
      src: villeNancyLogo,
      className: "is-wide is-ville-nancy",
      width: 1333,
      height: 551,
    };
  }

  if (sponsor === "Métropole du Grand Nancy") {
    return {
      src: grandNancyLogo,
      className: "is-wide",
      width: 300,
      height: 120,
    };
  }

  return null;
};
---

<section id="sponsors" class="dark">
  <div class="wrap">
    <h2 class="section-title">Ils soutiennent le club.</h2>
    <p class="intro">
      Partenaires institutionnels qui accompagnent le développement du roller de
      vitesse à Nancy.
    </p>
    <div class="partners-grid">
      {
        sponsors.map((sponsor) => {
          const logo = getSponsorLogo(sponsor);

          return (
            <article class="partner-card">
              <div
                class={`partner-logo ${logo?.className ?? ""}`}
                aria-hidden="true"
              >
                <div class="partner-logo-inner">
                  {logo ? (
                    <Image
                      src={logo.src}
                      alt=""
                      width={logo.width}
                      height={logo.height}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span>{sponsor}</span>
                  )}
                </div>
              </div>
              <strong>Partenaire institutionnel</strong>
              <h3>{sponsor}</h3>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .partners-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-top: 34px;
  }

  .partner-card {
    display: flex;
    min-height: 252px;
    flex-direction: column;
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.08);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .partner-card:hover,
  .partner-card:focus-within {
    transform: translateY(-2px);
    border-color: rgba(149, 194, 61, 0.48);
    background: rgba(255, 255, 255, 0.11);
  }

  .partner-logo {
    display: grid;
    flex: 1;
    min-height: 146px;
    margin-bottom: 20px;
    overflow: hidden;
    border: 1px solid rgba(16, 21, 16, 0.08);
    border-radius: 24px;
    background: linear-gradient(180deg, #ffffff, #f6f7f1);
  }

  .partner-logo-inner {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    padding: 28px 34px;
  }

  .partner-logo :global(img) {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1) brightness(0.44) contrast(0.92);
    opacity: 0.74;
    transition:
      filter 0.22s ease,
      opacity 0.22s ease;
  }

  .partner-logo.is-wide :global(img) {
    max-width: min(100%, 280px);
    max-height: 92px;
  }

  .partner-logo.is-ville-nancy :global(img) {
    max-width: min(100%, 320px);
    max-height: 120px;
  }

  .partner-logo span {
    color: var(--ink);
    font-family: var(--display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
    text-align: center;
  }

  .partner-card:hover .partner-logo :global(img),
  .partner-card:focus-within .partner-logo :global(img) {
    filter: none;
    opacity: 1;
  }

  .partner-card strong {
    display: block;
    margin-bottom: 8px;
    color: var(--club);
    font-family: var(--display);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .partner-card h3 {
    margin: 0;
    color: white;
    font-size: clamp(1.25rem, 2.2vw, 1.55rem);
    line-height: 1.08;
  }

  @media (hover: none) {
    .partner-logo :global(img) {
      filter: grayscale(0);
      opacity: 1;
    }
  }

  @media (max-width: 720px) {
    .partners-grid {
      grid-template-columns: 1fr;
    }

    .partner-card {
      min-height: 0;
    }
  }
</style>
