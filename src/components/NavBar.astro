---
import { Image } from "astro:assets";
import logoNrv from "../assets/brand/logo-nrv.png";

interface Props {
  site: {
    helloAssoUrl: string;
  };
}

const { site } = Astro.props;
---

<nav class="nav" aria-label="Navigation principale">
  <a class="brand" href="#accueil" aria-label="Retour à l'accueil">
    <Image src={logoNrv} alt="" width={140} height={46} decoding="async" />
  </a>
  <div class="links">
    <a href="#groupes" data-section-link>Groupes</a>
    <a href="#tarifs" data-section-link>Tarifs</a>
    <a href="#club" data-section-link>Club</a>
    <a href="#galerie" data-section-link>Galerie</a>
    <a href="#contact" data-section-link>Contact</a>
  </div>
  <a
    class="button"
    href={site.helloAssoUrl}
    target="_blank"
    rel="noreferrer"
    data-join-cta
  >
    S'INSCRIRE
  </a>
</nav>
<div class="scroll-progress" aria-hidden="true"></div>
