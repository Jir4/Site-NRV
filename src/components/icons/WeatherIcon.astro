---
interface Props {
  icon: "sun" | "rain" | "winter" | string;
}

const { icon } = Astro.props;
---

{
  icon === "sun" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2" />
      <path
        d="M12 2.5v3M12 18.5v3M21.5 12h-3M5.5 12h-3M18.7 5.3l-2.1 2.1M7.4 16.6l-2.1 2.1M18.7 18.7l-2.1-2.1M7.4 7.4 5.3 5.3"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      />
    </svg>
  )
}

{
  icon === "rain" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M7 15.5h9.3a3.7 3.7 0 0 0 .7-7.3 5.5 5.5 0 0 0-10.4 1.5A3 3 0 0 0 7 15.5Z"
        stroke="currentColor"
        stroke-width="2"
        stroke-linejoin="round"
      />
      <path
        d="M8 19l-1 2M13 19l-1 2M18 19l-1 2"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      />
    </svg>
  )
}

{
  icon === "winter" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M12 3v18M5.6 6.2l12.8 11.6M18.4 6.2 5.6 17.8"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      />
      <circle cx="12" cy="12" r="2" fill="currentColor" />
    </svg>
  )
}
