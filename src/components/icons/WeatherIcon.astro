---
import { CloudRain, Snowflake, Sun } from "lucide-astro";

interface Props {
  icon: "sun" | "rain" | "winter" | string;
}

const { icon } = Astro.props;
---

{
  icon === "sun" && <Sun width={14} height={14} aria-hidden="true" focusable="false" />
}

{
  icon === "rain" && <CloudRain width={14} height={14} aria-hidden="true" focusable="false" />
}

{
  icon === "winter" && <Snowflake width={14} height={14} aria-hidden="true" focusable="false" />
}
