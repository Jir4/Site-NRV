---
import { Image } from "astro:assets";
import { ChevronLeft, CreditCard, Expand, FileText, Instagram, Mail, Phone, Star, X } from "lucide-astro";
import type { Contact, SiteConfig } from "../data/site";
import { obfuscatePhone } from "../utils/phone";
import contactPhoto0 from "../assets/club/photo0.webp";
import contactPhoto1 from "../assets/club/photo1.webp";
import contactPhoto2 from "../assets/club/photo2.webp";
import presidentKonamiPhoto from "../assets/easter-eggs/president-konami.png";

interface Props {
  site: SiteConfig;
}
const { site } = Astro.props;

const isPhone = (detail?: string): boolean => {
  const digits = detail?.replaceAll(".", "").replaceAll(" ", "");
  return !!(digits && /^\d+$/.test(digits));
};

const president = site.contacts.find((contact) => contact.role === "Président");
const presidentPhone = isPhone(president?.detail)
  ? obfuscatePhone(president!.detail!)
  : null;
const roleDescriptions: Partial<Record<Contact["role"], string>> = {
  Président:
    "Coordination du club et premier contact pour les familles et nouveaux adhérents.",
  Trésorier: "Cotisations, inscriptions et suivi administratif de la saison.",
  Secrétaire:
    "Vie du club, circulation des informations et organisation interne.",
};
const rolePortraits: Partial<
  Record<
    Contact["role"],
    { src: ImageMetadata; alt: string; easterSrc?: ImageMetadata }
  >
> = {
  Président: {
    src: contactPhoto0,
    alt: "",
    easterSrc: presidentKonamiPhoto,
  },
  Trésorier: { src: contactPhoto1, alt: "" },
  Secrétaire: { src: contactPhoto2, alt: "" },
};
const presidentEasterPhoto = rolePortraits.Président?.easterSrc;

const getInitials = (name: string): string =>
  name
    .split(" ")
    .map((w) => w[0])
    .join("")
    .slice(0, 2);
---

<section class="light" id="contact">
  <div class="wrap split">
    <div>
      <h2 class="section-title">Une question avant d’essayer ?</h2>
      <p class="intro">
        Contacte le club ou suis les derniers moments de Nancy Roller Vitesse
        sur Instagram.
      </p>
      <div class="contact-actions" aria-label="Actions de contact du club">
        <a
          class="contact-action"
          href={`mailto:${site.email}`}
          aria-label="Nous écrire"
        >
          <span class="contact-action__icon" aria-hidden="true">
            <Mail focusable="false" />
          </span>
          <span class="contact-action__label">Nous écrire</span>
        </a>
        {
          presidentPhone && (
            <a
              class="contact-action"
              href="#"
              data-phone={presidentPhone}
              data-phone-display="none"
              aria-label="Nous appeler"
            >
              <span class="contact-action__icon" aria-hidden="true">
                <Phone focusable="false" />
              </span>
              <span class="contact-action__label">Nous appeler</span>
            </a>
          )
        }
        <a
          class="contact-action contact-action--instagram"
          href={site.instagramUrl}
          target="_blank"
          rel="noreferrer"
          aria-label="Instagram"
        >
          <span class="contact-action__icon" aria-hidden="true">
            <Instagram focusable="false" />
          </span>
          <span class="contact-action__label">Instagram</span>
        </a>
      </div>
    </div>
    <div class="cards cards-single">
      {
        site.contacts.map((contact: Contact) => {
          const isPresident = contact.role === "Président";
          const showPhoneInCard = !isPresident && isPhone(contact.detail);
          const showDetailInCard =
            !isPresident && !showPhoneInCard && !!contact.detail;
          const phoneEncoded = showPhoneInCard
            ? obfuscatePhone(contact.detail!)
            : null;
          const description =
            roleDescriptions[contact.role] ?? "Bureau de l'association.";
          const portrait = rolePortraits[contact.role];
          return (
            <article
              class={`card contact-card ${isPresident ? "is-primary-contact" : ""}`}
              data-konami-president-card={isPresident ? true : undefined}
              style={
                isPresident
                  ? "--president-easter-x: 50%; --president-easter-y: 18%;"
                  : undefined
              }
            >
              <div class="contact-card-inner">
                <div class="contact-card-face contact-card-front">
                  <div class="contact-body">
                    <div class="contact-topline">
                      <h3>{contact.name}</h3>
                      <span class="contact-role">
                        {contact.role === "Président" && (
                          <span class="contact-role-icon" aria-hidden="true"><Star focusable="false" /></span>
                        )}
                        {contact.role === "Trésorier" && (
                          <span class="contact-role-icon" aria-hidden="true"><CreditCard focusable="false" /></span>
                        )}
                        {contact.role === "Secrétaire" && (
                          <span class="contact-role-icon" aria-hidden="true"><FileText focusable="false" /></span>
                        )}
                        <strong>{contact.role}</strong>
                      </span>
                    </div>
                    <div class="contact-identity">
                      <div class="contact-avatar" aria-hidden="true">
                        {portrait ? (
                          <Image
                            class="contact-portrait"
                            src={portrait.src}
                            alt={portrait.alt}
                            width={136}
                            height={136}
                            loading="lazy"
                            decoding="async"
                          />
                        ) : (
                          <span>{getInitials(contact.name)}</span>
                        )}
                      </div>
                      <div class="contact-name-block">
                        <p class="contact-description">{description}</p>
                        <p class="contact-signature">Nancy Roller Vitesse</p>
                      </div>
                    </div>
                    {phoneEncoded ? (
                      <p>
                        <a
                          href="#"
                          class="contact-phone"
                          data-phone={phoneEncoded}
                        />
                      </p>
                    ) : showDetailInCard ? (
                      <p>{contact.detail}</p>
                    ) : (
                      <p class="contact-meta" aria-hidden="true" />
                    )}
                  </div>
                </div>
                {isPresident && portrait?.easterSrc && (
                  <div
                    class="contact-card-face contact-card-back"
                    data-konami-back
                    aria-hidden="true"
                  >
                    <Image
                      class="contact-card-back-image"
                      src={portrait.easterSrc}
                      alt=""
                      width={720}
                      height={720}
                      loading="lazy"
                      decoding="async"
                    />
                    <div
                      class="contact-card-back-actions"
                      role="group"
                      aria-label="Actions de la photo cachée"
                    >
                      <button
                        class="contact-card-icon-button"
                        type="button"
                        data-konami-expand
                        tabindex="-1"
                        aria-label="Afficher la photo en grand"
                      >
                        <Expand aria-hidden="true" focusable="false" />
                      </button>
                      <button
                        class="contact-card-icon-button"
                        type="button"
                        data-konami-reset
                        tabindex="-1"
                        aria-label="Revenir à la carte du président"
                      >
                        <ChevronLeft aria-hidden="true" focusable="false" />
                      </button>
                    </div>
                  </div>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

{
  presidentEasterPhoto && (
    <dialog
      class="konami-lightbox"
      data-konami-dialog
      aria-label="Photo du président en grand"
    >
      <button
        class="konami-lightbox-close"
        type="button"
        data-konami-dialog-close
        aria-label="Fermer la photo agrandie"
      >
        <X aria-hidden="true" focusable="false" />
      </button>
      <Image
        class="konami-lightbox-image"
        src={presidentEasterPhoto}
        alt="Photo cachée du président du club"
        width={1440}
        height={1440}
        loading="lazy"
        decoding="async"
      />
    </dialog>
  )
}

<script>
  import { revealPhones } from "../utils/phone";
  revealPhones();
</script>

<style>
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .contact-action {
    display: inline-flex;
    align-items: center;
    gap: 0;
    min-height: 52px;
    padding: 0 16px;
    overflow: hidden;
    border: 1px solid rgba(16, 21, 16, 0.12);
    border-radius: 999px;
    background: white;
    color: var(--ink);
    text-decoration: none;
    box-shadow: 0 14px 28px rgba(16, 21, 16, 0.08);
    transition:
      padding 220ms ease 110ms,
      gap 220ms ease 110ms,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .contact-action:hover,
  .contact-action:focus-visible {
    padding-right: 18px;
    gap: 10px;
    border-color: rgba(149, 194, 61, 0.55);
    box-shadow: 0 18px 38px rgba(16, 21, 16, 0.14);
    transition-delay: 0s;
  }

  .contact-action:focus-visible {
    outline: 2px solid rgba(149, 194, 61, 0.55);
    outline-offset: 2px;
  }

  .contact-action__icon {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    color: var(--ink);
  }

  .contact-action__icon :global(svg) {
    width: 20px;
    height: 20px;
  }

  .contact-action__label {
    max-width: 0;
    overflow: hidden;
    opacity: 0;
    white-space: nowrap;
    font-family: var(--display);
    font-weight: 800;
    letter-spacing: 0.04em;
    transition:
      max-width 220ms ease 110ms,
      opacity 140ms ease 110ms;
  }

  .contact-action:hover .contact-action__label,
  .contact-action:focus-visible .contact-action__label {
    max-width: 13ch;
    opacity: 1;
    transition-delay: 0s;
  }

  .contact-action--instagram {
    position: relative;
  }

  .contact-action--instagram::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 2px;
    background: linear-gradient(135deg, #feda77, #dd2a7b, #8134af, #515bd4);
    opacity: 0;
    transition: opacity 0.2s ease;
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    mask-composite: exclude;
  }

  .contact-action--instagram:hover,
  .contact-action--instagram:focus-visible {
    border-color: transparent;
  }

  .contact-action--instagram:hover::before,
  .contact-action--instagram:focus-visible::before {
    opacity: 1;
  }

  .contact-action--instagram .contact-action__icon,
  .contact-action--instagram .contact-action__label {
    position: relative;
    z-index: 1;
  }

  .contact-card {
    position: relative;
    padding: 20px;
    border-color: rgba(16, 21, 16, 0.09);
    border-radius: 30px;
    background:
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.98),
        rgba(244, 246, 237, 0.98) 56%,
        rgba(240, 243, 231, 0.98)
      ),
      white;
    box-shadow:
      0 18px 38px rgba(16, 21, 16, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .contact-card.is-primary-contact {
    perspective: 1200px;
  }

  .contact-card-inner {
    position: relative;
    z-index: 1;
    min-height: 100%;
  }

  .contact-card.is-primary-contact .contact-card-inner {
    transform-style: preserve-3d;
    transition: transform 560ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  :global(html.is-konami-unlocked)
    .contact-card.is-primary-contact
    .contact-card-inner {
    transform: rotateY(180deg);
  }

  .contact-card-face {
    min-height: 100%;
  }

  .contact-card.is-primary-contact .contact-card-face {
    border-radius: 30px;
    backface-visibility: hidden;
  }

  .contact-card.is-primary-contact .contact-card-back {
    overflow: hidden;
  }

  .contact-card-back {
    position: absolute;
    inset: 0;
    min-height: 100%;
    transform: rotateY(180deg);
    background: var(--ink);
  }

  .contact-card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    background:
      linear-gradient(115deg, rgba(149, 194, 61, 0.14), transparent 24%),
      linear-gradient(transparent 0 0);
    pointer-events: none;
  }

  .contact-avatar {
    display: grid;
    flex-shrink: 0;
    place-items: center;
    width: 96px;
    height: 96px;
    padding: 4px;
    border: 1px solid rgba(16, 21, 16, 0.08);
    border-radius: 26px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.98),
      rgba(239, 242, 232, 0.96)
    );
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .contact-avatar :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 22px;
  }

  .contact-card-back-image {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 224px;
    object-fit: cover;
    object-position: var(--president-easter-x, 50%)
      var(--president-easter-y, 50%);
  }

  .contact-card-back-actions {
    position: absolute;
    top: 14px;
    right: 14px;
    display: flex;
    gap: 8px;
  }

  .contact-card-icon-button {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.34);
    border-radius: 999px;
    background: rgba(16, 21, 16, 0.56);
    color: white;
    cursor: pointer;
    backdrop-filter: blur(10px);
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .contact-card-icon-button:hover,
  .contact-card-icon-button:focus-visible {
    transform: translateX(-2px);
    border-color: rgba(149, 194, 61, 0.75);
    background: rgba(16, 21, 16, 0.72);
  }

  .contact-card-icon-button:focus-visible {
    outline: 2px solid rgba(149, 194, 61, 0.7);
    outline-offset: 2px;
  }

  .contact-card-icon-button :global(svg) {
    width: 20px;
    height: 20px;
  }

  .konami-lightbox {
    width: min(92vw, 980px);
    max-height: 90vh;
    padding: 0;
    border: 0;
    border-radius: 34px;
    background: var(--ink);
    overflow: hidden;
    box-shadow: 0 34px 90px rgba(16, 21, 16, 0.45);
  }

  .konami-lightbox::backdrop {
    background: rgba(16, 21, 16, 0.74);
    backdrop-filter: blur(12px);
  }

  .konami-lightbox-image {
    display: block;
    width: 100%;
    max-height: 90vh;
    object-fit: contain;
  }

  .konami-lightbox-close {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.36);
    border-radius: 999px;
    background: rgba(16, 21, 16, 0.58);
    color: white;
    cursor: pointer;
    backdrop-filter: blur(10px);
  }

  .konami-lightbox-close:focus-visible {
    outline: 2px solid rgba(149, 194, 61, 0.7);
    outline-offset: 2px;
  }

  .konami-lightbox-close :global(svg) {
    width: 20px;
    height: 20px;
  }

  .contact-avatar span {
    color: var(--club-text);
    font-family: var(--display);
    font-size: 1.45rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .contact-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
  }

  .contact-topline {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 16px;
    padding-top: 2px;
  }

  .contact-role {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    gap: 3px;
    min-height: 20px;
  }

  .contact-role strong {
    margin-top: 0;
  }
  .contact-role-icon {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: var(--club-text);
    opacity: 0.82;
  }

  .contact-role-icon :global(svg) {
    display: block;
    width: 18px;
    height: 18px;
  }

  .contact-identity {
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }

  .contact-name-block {
    min-width: 0;
    padding-top: 4px;
  }

  .contact-body strong {
    display: inline-flex;
    align-items: center;
    min-height: 20px;
    flex-shrink: 0;
    margin-bottom: 0;
    color: var(--club-text);
    font-family: var(--display);
    font-size: 0.86rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    line-height: 1;
    text-align: right;
    text-transform: uppercase;
  }

  .contact-body h3 {
    margin: 0;
    min-width: 0;
    font-size: 1.46rem;
    line-height: 1.02;
    letter-spacing: -0.03em;
    overflow-wrap: anywhere;
  }

  .contact-description,
  .contact-meta {
    margin: 0;
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .contact-signature {
    margin: 12px 0 0;
    color: var(--club-text);
    font-family: var(--display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .contact-meta {
    min-height: 1.2rem;
  }

  .contact-phone {
    display: inline-flex;
    align-self: flex-start;
    min-height: 40px;
    align-items: center;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(149, 194, 61, 0.12);
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    transition:
      transform 0.2s ease,
      color 0.2s ease,
      background 0.2s ease;
  }

  .contact-phone:hover {
    color: var(--club-text);
    background: rgba(149, 194, 61, 0.18);
    transform: translateY(-1px);
  }

  @media (max-width: 540px) {
    .contact-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .contact-action,
    .contact-action:hover,
    .contact-action:focus-visible {
      width: 100%;
      gap: 10px;
      padding-right: 16px;
      transition-delay: 0s;
    }

    .contact-action__label,
    .contact-action:hover .contact-action__label,
    .contact-action:focus-visible .contact-action__label {
      max-width: 120px;
      opacity: 1;
    }

    .contact-avatar {
      width: 72px;
      height: 72px;
    }

    .contact-topline {
      grid-template-columns: 1fr;
      align-items: flex-start;
      gap: 8px;
    }

    .contact-body strong {
      font-size: 0.8rem;
    }

    .contact-avatar :global(img) {
      border-radius: 18px;
    }

    .contact-identity {
      align-items: flex-start;
    }

    .contact-card-back-actions,
    .konami-lightbox {
      display: none;
    }
  }

  @media (hover: none), (pointer: coarse) {
    .contact-card-back-actions,
    .konami-lightbox {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-card.is-primary-contact .contact-card-inner {
      transform: none !important;
      transition: none;
    }

    .contact-card.is-primary-contact .contact-card-front,
    .contact-card.is-primary-contact .contact-card-back {
      transition: opacity 120ms ease;
    }

    .contact-card.is-primary-contact .contact-card-back {
      transform: none;
      opacity: 0;
      pointer-events: none;
    }

    :global(html.is-konami-unlocked)
      .contact-card.is-primary-contact
      .contact-card-front {
      opacity: 0;
    }

    :global(html.is-konami-unlocked)
      .contact-card.is-primary-contact
      .contact-card-back {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>
