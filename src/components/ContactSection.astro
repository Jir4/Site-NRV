---
import type { Contact, SiteConfig } from "../data/site";
import { obfuscatePhone } from "../utils/phone";

interface Props { site: SiteConfig }
const { site } = Astro.props;

const isPhone = (detail?: string): boolean => {
  const digits = detail?.replaceAll(".", "").replaceAll(" ", "");
  return !!(digits && /^\d+$/.test(digits));
};

const getInitials = (name: string): string =>
  name
    .split(" ")
    .map((w) => w[0])
    .join("")
    .slice(0, 2);
---

<section class="light" id="contact">
  <div class="wrap split">
    <div>
      <h2 class="section-title">Une question avant d’essayer ?</h2>
      <p class="intro">Contacte le club ou suis les derniers moments de Nancy Roller Vitesse sur Instagram.</p>
      <div class="hero-actions">
        <a class="button" href={`mailto:${site.email}`}>Écrire au club</a><a class="button secondary instagram-button" href={site.instagramUrl}><svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="2"></rect><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2"></circle><circle cx="17" cy="7" r="1.4" fill="currentColor"></circle></svg><span>Instagram</span></a>
      </div>
    </div>
    <div class="cards cards-single">
      {site.contacts.map((contact: Contact) => {
        const phoneEncoded = isPhone(contact.detail) ? obfuscatePhone(contact.detail!) : null;

        return (
          <article class="card contact-card">
            <div class="contact-avatar" aria-hidden="true">
              <svg viewBox="0 0 80 80" width="80" height="80">
                <circle cx="40" cy="40" r="40" fill="var(--club)" />
                <text x="40" y="40" text-anchor="middle" dominant-baseline="central" fill="white" font-size="26" font-weight="700" font-family="var(--display)">
                  {getInitials(contact.name)}
                </text>
              </svg>
            </div>
            <div class="contact-body">
              <strong>{contact.role}</strong>
              <h3>{contact.name}</h3>
              {phoneEncoded ? (
                <p><a href="#" class="contact-phone" data-phone={phoneEncoded}></a></p>
              ) : contact.detail ? (
                <p>{contact.detail}</p>
              ) : (
                <p aria-hidden="true">&nbsp;</p>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<script>
  import { revealPhones } from "../utils/phone";
  revealPhones();
</script>

<style>
  .contact-card {
    display: flex;
    gap: 20px;
    align-items: stretch;
  }

  .contact-avatar {
    flex-shrink: 0;
    align-self: flex-start;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
  }

  .contact-avatar svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .contact-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4px 0;
  }

  .contact-body strong {
    display: inline-block;
    padding: 3px 12px;
    border-radius: 999px;
    background: rgba(149, 194, 61, 0.12);
    color: var(--club-text);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    margin-bottom: 10px;
  }

  .contact-body h3 {
    margin: 0 0 6px;
    font-size: 1.35rem;
  }

  .contact-phone {
    font-weight: 600;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: rgba(149, 194, 61, 0.35);
    text-underline-offset: 4px;
    transition:
      color 0.2s ease,
      text-decoration-color 0.2s ease;
  }

  .contact-phone:hover {
    color: var(--club-text);
    text-decoration-color: var(--club);
  }

  @media (max-width: 540px) {
    .contact-avatar {
      width: 64px;
      height: 64px;
    }

    .contact-card {
      gap: 16px;
    }
  }
</style>
