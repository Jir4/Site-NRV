---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Photo {
  src: ImageMetadata;
  alt: string;
}

interface Props {
  photos: Photo[];
  interval?: number;
}

const { photos, interval = 2500 } = Astro.props;

const visiblePhotos = photos.slice(0, 5);
---

<div
  class="photo-stack"
  data-photo-stack
  data-interval={interval}
  aria-label="Galerie photos du club"
>
  {
    visiblePhotos.map((photo, index) => (
      <Image
        class="photo-stack__image"
        src={photo.src}
        alt={index === 0 ? photo.alt : ""}
        width={photo.src.width}
        height={photo.src.height}
        widths={[480, 768, 1024, 1200]}
        sizes="(max-width: 840px) 92vw, 48vw"
        loading={index === 0 ? "eager" : "lazy"}
        fetchpriority={index === 0 ? "high" : "low"}
        decoding="async"
        data-alt={photo.alt}
        data-position={index}
        aria-hidden={index === 0 ? undefined : "true"}
      />
    ))
  }
</div>

<style>
  .photo-stack {
    position: relative;
    min-height: 430px;
    isolation: isolate;
  }

  .photo-stack__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 42px;
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.28);
    transition:
      transform 500ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 500ms ease;
  }

  .photo-stack__image[data-position="0"] {
    z-index: 5;
    opacity: 1;
    transform: translate(0, 0) rotate(0deg) scale(1);
  }

  .photo-stack__image[data-position="1"] {
    z-index: 4;
    opacity: 0.9;
    transform: translate(14px, 8px) rotate(2.5deg) scale(0.98);
  }

  .photo-stack__image[data-position="2"] {
    z-index: 3;
    opacity: 0.75;
    transform: translate(-12px, 14px) rotate(-2deg) scale(0.96);
  }

  .photo-stack__image[data-position="3"] {
    z-index: 2;
    opacity: 0.55;
    transform: translate(20px, 18px) rotate(4deg) scale(0.94);
  }

  .photo-stack__image[data-position="4"] {
    z-index: 1;
    opacity: 0.35;
    transform: translate(-18px, 22px) rotate(-4deg) scale(0.92);
  }

  @media (max-width: 840px) {
    .photo-stack {
      min-height: 300px;
    }

    .photo-stack__image {
      box-shadow: 0 14px 32px rgba(0, 0, 0, 0.24);
    }

    .photo-stack__image[data-position="2"],
    .photo-stack__image[data-position="3"],
    .photo-stack__image[data-position="4"] {
      opacity: 0;
      pointer-events: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-stack__image {
      transition: none;
    }
  }
</style>
