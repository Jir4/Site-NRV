---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { ChevronLeft, ChevronRight, X } from "lucide-astro";

const imageModules = import.meta.glob("../assets/gallery/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}", {
  eager: true,
  import: "default",
}) as Record<string, ImageMetadata>;

const galleryPhotos = Object.entries(imageModules)
  .sort(([firstPath], [secondPath]) => firstPath.localeCompare(secondPath, undefined, { numeric: true }))
  .map(([, src], index) => ({
    src,
    index,
    alt: `Photo du Nancy Roller Vitesse ${index + 1}`,
  }));

const visiblePhotos = galleryPhotos.slice(0, 5);
---

<section id="galerie" class="dark">
  <div class="wrap">
    <h2 class="section-title">La vitesse en images.</h2>
    <p class="intro">
      Entraînements, compétitions et moments de club : un aperçu vivant de la
      piste et du collectif.
    </p>
    <div class="gallery" aria-label="Galerie photos du club">
      {
        visiblePhotos.map((photo, slotIndex) => (
          <button
            class="shot"
            type="button"
            data-gallery-slot
            data-gallery-current-index={photo.index}
            aria-label={`Agrandir ${photo.alt}`}
          >
            <Image
              data-gallery-image
              src={photo.src}
              alt={photo.alt}
              widths={[420, 760, 1200]}
              sizes="(max-width: 840px) 92vw, (max-width: 1180px) 31vw, 380px"
              loading={slotIndex === 0 ? "eager" : "lazy"}
              fetchpriority={slotIndex === 0 ? "high" : "low"}
              decoding="async"
            />
          </button>
        ))
      }
    </div>

    <div class="gallery-sources" aria-hidden="true">
      {
        galleryPhotos.map((photo) => (
          <Image
            data-gallery-source
            data-gallery-index={photo.index}
            src={photo.src}
            alt={photo.alt}
            widths={[420, 860, 1400, 1800]}
            sizes="(max-width: 840px) 92vw, 86vw"
            loading="lazy"
            decoding="async"
          />
        ))
      }
    </div>
  </div>

  <dialog class="gallery-lightbox" data-gallery-dialog aria-label="Galerie photos du club">
    <div class="gallery-lightbox__frame">
      <button class="gallery-lightbox__close" type="button" data-gallery-close aria-label="Fermer la galerie">
        <X aria-hidden="true" focusable="false" />
      </button>
      <button class="gallery-lightbox__nav is-prev" type="button" data-gallery-prev aria-label="Photo précédente">
        <ChevronLeft aria-hidden="true" focusable="false" />
      </button>
      <img class="gallery-lightbox__image" data-gallery-lightbox-image alt="" />
      <button class="gallery-lightbox__nav is-next" type="button" data-gallery-next aria-label="Photo suivante">
        <ChevronRight aria-hidden="true" focusable="false" />
      </button>
    </div>
  </dialog>
</section>

<style>
  .gallery {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr 1fr;
    grid-auto-rows: 190px;
    gap: 16px;
    margin-top: 34px;
  }

  .shot {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    padding: 0;
    background: rgba(255, 255, 255, 0.06);
    cursor: zoom-in;
    isolation: isolate;
    transition:
      border-color 220ms ease,
      transform 220ms ease,
      opacity 180ms ease;
  }

  .shot:hover {
    border-color: rgba(149, 194, 61, 0.72);
    transform: translateY(-3px);
  }

  .shot:focus-visible {
    outline: 3px solid var(--green);
    outline-offset: 4px;
  }

  .shot.is-changing {
    opacity: 0.36;
  }

  .shot :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .shot:hover :global(img) {
    transform: scale(1.045);
  }

  .shot:nth-child(1) {
    grid-row: span 2;
  }

  .gallery-sources {
    display: none;
  }

  .gallery-lightbox {
    width: min(1180px, calc(100vw - 32px));
    max-height: calc(100vh - 32px);
    padding: 0;
    border: 0;
    border-radius: 34px;
    background: rgba(6, 10, 18, 0.94);
    color: #fff;
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.52);
  }

  .gallery-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(8px);
  }

  .gallery-lightbox__frame {
    position: relative;
    display: grid;
    padding: 14px;
  }

  .gallery-lightbox__image {
    display: block;
    width: 100%;
    max-height: min(82vh, 820px);
    object-fit: contain;
    border-radius: 24px;
    background: #05070d;
  }

  .gallery-lightbox__close,
  .gallery-lightbox__nav {
    display: grid;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    background: rgba(8, 12, 20, 0.64);
    color: #fff;
    cursor: pointer;
    font: inherit;
    backdrop-filter: blur(12px);
    transition:
      background 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .gallery-lightbox__close :global(svg),
  .gallery-lightbox__nav :global(svg) {
    width: 22px;
    height: 22px;
    stroke-width: 2.2;
  }

  .gallery-lightbox__close:hover,
  .gallery-lightbox__nav:hover {
    border-color: rgba(149, 194, 61, 0.78);
    background: rgba(149, 194, 61, 0.22);
  }

  .gallery-lightbox__close:focus-visible,
  .gallery-lightbox__nav:focus-visible {
    outline: 3px solid var(--green);
    outline-offset: 3px;
  }

  .gallery-lightbox__close {
    position: absolute;
    top: 26px;
    right: 26px;
    z-index: 2;
    width: 46px;
    height: 46px;
  }

  .gallery-lightbox__nav {
    position: absolute;
    top: 50%;
    z-index: 1;
    width: 52px;
    height: 52px;
    transform: translateY(-50%);
  }

  .gallery-lightbox__nav.is-prev {
    left: 28px;
  }

  .gallery-lightbox__nav.is-next {
    right: 28px;
  }

  @media (max-width: 840px) {
    .gallery {
      grid-template-columns: 1fr;
      grid-auto-rows: 200px;
    }

    .shot:nth-child(1) {
      grid-row: span 1;
    }

    .gallery-lightbox {
      width: calc(100vw - 18px);
      border-radius: 24px;
    }

    .gallery-lightbox__frame {
      padding: 10px;
    }

    .gallery-lightbox__image {
      max-height: 78vh;
      border-radius: 18px;
    }

    .gallery-lightbox__close {
      top: 20px;
      right: 20px;
      width: 44px;
      height: 44px;
    }

    .gallery-lightbox__nav {
      top: auto;
      bottom: 22px;
      width: 48px;
      height: 48px;
      transform: none;
    }

    .gallery-lightbox__nav.is-prev {
      left: 18px;
    }

    .gallery-lightbox__nav.is-next {
      right: 18px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .shot,
    .shot :global(img),
    .gallery-lightbox__close,
    .gallery-lightbox__nav {
      transition: none;
    }

    .shot:hover {
      transform: none;
    }
  }
</style>
